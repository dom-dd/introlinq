# Copy this file to .env.local and fill in the values.
# .env.local is gitignored - never commit real keys.

# Same Neon Postgres database the main app uses. Discovery writes to its own
# tables (candidate_publishers, discovery_queries) so it can't affect the
# live product's data.
DATABASE_URL=

# https://serpapi.com/manage-api-key
SERPAPI_KEY=

# https://console.anthropic.com/settings/keys - used by classify.js to
# categorize leads (publisher/vendor/competitor)
ANTHROPIC_API_KEY=

# https://developer.apollo.io - used by enrich.js to find contact names and
# reveal emails. Requires a master API key with People Search + People
# Match/Enrichment access. Enrichment calls consume Apollo credits.
APOLLO_API_KEY=

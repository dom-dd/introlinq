# Copy this file to .env.local and fill in the values.
# .env.local is gitignored - never commit real keys.

# Same Neon Postgres database the main app uses. Discovery writes to its own
# tables (candidate_publishers, discovery_queries) so it can't affect the
# live product's data.
DATABASE_URL=

# https://serpapi.com/manage-api-key
SERPAPI_KEY=
